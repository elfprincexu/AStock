# =============================================================
#  AStock Environment Configuration
#  Copy this file to .env and modify as needed:
#    cp .env.example .env
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=astock
POSTGRES_PASSWORD=astock123
POSTGRES_DB=astock
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Service Ports ─────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=80
GRAFANA_PORT=3000

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── JWT Authentication ────────────────────────────────────────
# IMPORTANT: Change this in production!
JWT_SECRET_KEY=astock-jwt-secret-change-in-production-2026
JWT_EXPIRE_MINUTES=1440

# ── Display Timezone ──────────────────────────────────────────
DISPLAY_TIMEZONE=Asia/Shanghai

# ── Data Sources ──────────────────────────────────────────────
DATA_SOURCE_PRIORITY=akshare,tushare,baostock,eastmoney,sina,tencent
DATA_SOURCE_TIMEOUT=10
# Optional: Tushare API token (register at https://tushare.pro)
TUSHARE_TOKEN=

# ── AI / LLM Configuration ───────────────────────────────────
# Uncomment and fill in ONE provider section below:

# --- Option A: OpenAI / OpenAI-compatible ---
# LITELLM_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=

# --- Option B: Gemini ---
# LITELLM_MODEL=gemini/gemini-2.5-flash
# GEMINI_API_KEY=your-gemini-key

# --- Option C: Anthropic ---
# LITELLM_MODEL=anthropic/claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=your-anthropic-key

# --- Option D: DeepSeek ---
# LITELLM_MODEL=deepseek/deepseek-chat
# OPENAI_API_KEY=your-deepseek-key

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192
LLM_REQUEST_TIMEOUT=120
LLM_SSL_VERIFY=true

# ── Broker (Live Trading, optional) ──────────────────────────
# BROKER_ACCOUNT=
# BROKER_PASSWORD=
# BROKER_QMT_PATH=
